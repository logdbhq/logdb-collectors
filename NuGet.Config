<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- GitHub Packages feed for the logdbhq org. Authoritative source for LogDB.*
         packages — kept in sync by the publish-*-on-tag workflows in logdb-sdk,
         which push to both NuGet.org AND here. Restore requires a PAT with
         read:packages scope.

         Credentials are NOT committed here:
         - Local dev: source name "github" matches the user-level NuGet.Config
           (~/AppData/Roaming/NuGet/NuGet.Config) so its PAT is inherited
           automatically.
         - CI: .github/workflows/release.yml injects credentials into this file
           at runtime via `dotnet nuget update source github` using the auto-issued
           GITHUB_TOKEN. The injection is ephemeral (the runner is torn down after
           the job) so no secret ever lands in a commit. -->
    <add key="github" value="https://nuget.pkg.github.com/logdbhq/index.json" />
  </packageSources>
</configuration>
