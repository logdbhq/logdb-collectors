<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- GitHub Packages feed for the logdbhq org. Authoritative source for LogDB.*
         packages — kept in sync by the publish-*-on-tag workflows in logdb-sdk,
         which now push to both NuGet.org AND here. Restore requires a PAT with
         read:packages scope. Source name "github" is reused from the user-level
         NuGet.Config so credentials are inherited automatically (the tracked file
         here stays creds-free). -->
    <add key="github" value="https://nuget.pkg.github.com/logdbhq/index.json" />
    <!-- Temporary local feed for the in-flight LogDB.Client 5.1.2 build (Heartbeat
         LogBeat.Environment wire-mapping fix in logdb-sdk LogGrpcMapper.cs). Lets
         the collectors build today against the patched SDK before the publish
         workflow runs. Drop once `client-v5.1.2` is tagged and the workflow has
         pushed to the logdbhq GitHub Packages feed. -->
    <add key="logdb-local" value="C:\tmp\logdb-local-feed" />
  </packageSources>
</configuration>
