{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "LogDB": {
    "ApiKey": "",
    "GuardUrl": ""
  },
  "Firewall": {
    "SyncIntervalMinutes": 15,
    "RulePrefix": "LogDB Firewall",
    "Direction": "Inbound",
    "DryRun": false,
    "MaxIpsPerRule": 5000,
    "PublicBlocklists": {
      "FireHOL_Level1": {
        "Enabled": true,
        "Url": "https://iplists.firehol.org/files/firehol_level1.netset"
      },
      "FireHOL_Level2": {
        "Enabled": true,
        "Url": "https://iplists.firehol.org/files/firehol_level2.netset"
      },
      "TorExitNodes": {
        "Enabled": true,
        "Url": "https://check.torproject.org/torbulkexitlist"
      },
      "IPsum": {
        "Enabled": true,
        "Url": "https://raw.githubusercontent.com/stamparm/ipsum/master/ipsum.txt",
        "MinScore": 3
      },
      "Blocklist_de": {
        "Enabled": true,
        "Url": "https://lists.blocklist.de/lists/all.txt"
      },
      "CINS_Army": {
        "Enabled": true,
        "Url": "http://cinsscore.com/list/ci-badguys.txt"
      }
    },
    "CustomBlocklist": {
      "Enabled": false
    },
    "WhitelistPath": ""
  },
  "Server": {
    "ServerName": "SERVER-01",
    "ServerEnvironment": "Production"
  },
  "_comments": {
    "LogDB:ApiKey": "Optional: Only needed for custom blocklist from LogDB Guard",
    "LogDB:GuardUrl": "Optional: Guard gRPC endpoint (e.g., https://guard.logdb.site)",
    "Firewall:SyncIntervalMinutes": "How often to sync blocklists to firewall rules",
    "Firewall:DryRun": "Set to true to log actions without modifying firewall rules",
    "Firewall:MaxIpsPerRule": "Maximum IPs per firewall rule before splitting into sub-rules",
    "Firewall:WhitelistPath": "Path to whitelist.txt file. Empty = defaults to whitelist.txt next to exe. IPs/CIDRs in this file are never blocked.",
    "Server:ServerName": "Unique identifier for this server"
  }
}
