{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "NginxTargets": {
    "ExcludeStaticFiles": true,
    "Targets": [
      {
        "Name": "default",
        "AccessLogPath": "/var/log/nginx/access.log",
        "ErrorLogPath": "/var/log/nginx/error.log",
        "Enabled": true
      }
    ]
  },
  "Checkpoint": {
    "Enabled": true,
    "FilePath": "checkpoints.json",
    "FlushIntervalSeconds": 15
  },
  "LogDbExporter": {
    "Enabled": false,
    "Endpoint": "http://localhost:5000",
    "ApiKey": "",
    "Collection": "nginx-logs",
    "Protocol": "Native",
    "FlushIntervalSeconds": 300,
    "MaxBatchBytes": 1048576,
    "MaxRetries": 3,
    "EnableCompression": true,
    "RequestTimeoutSeconds": 30
  },
  "Spool": {
    "Enabled": true,
    "DirectoryPath": "spool",
    "MaxDiskBytes": 2147483648,
    "MaxSegmentBytes": 10485760,
    "FlushIntervalSeconds": 1,
    "WhenFull": "DropOldest"
  }
}
