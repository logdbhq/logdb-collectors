{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "com.logdb.tracker": "Debug"
    }
  },
  "LogDB": {
    "ApiKey": "YOUR_API_KEY_HERE",
    "EnableBatching": false,
    "EnableCompression": true,
    "MaxRetries": 3,
    "EnableCircuitBreaker": true
  },
  "WindowsTracker": {
    "CollectionIntervalSeconds": 60,
    "Collection": "windows-metrics",
    "Metrics": {
      "CPU": true,
      "Memory": true,
      "Disk": true,
      "Network": false
    }
  },
  "Server": {
    "ServerName": "SERVER-01",
    "ServerEnvironment": "Production"
  },
  "_comments": {
    "LogDB:ApiKey": "Required: Your LogDB API key",
    "LogDB:ServiceUrl": "Optional: Override gRPC service URL (leave unset to use discovery service)",
    "WindowsTracker:CollectionIntervalSeconds": "How often to collect metrics (in seconds)",
    "Server:ServerName": "Unique identifier for this server"
  }
}
