{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "LogDB": {
    "ApiKey": "YOUR_API_KEY_HERE",
    "EnableBatching": false,
    "BatchSize": 100,
    "FlushIntervalSeconds": 5,
    "EnableCompression": true,
    "MaxRetries": 3,
    "EnableCircuitBreaker": true
  },
  "Server": {
    "ServerName": "SERVER-01",
    "ServerEnvironment": "Production"
  },
  "EventViewer": {
    "LogSources": [ "System", "Application" ],
    "EventLevels": [ "error", "warning", "information" ],
    "ExportIntervalMinutes": 1,
    "MaxEventsPerExport": 1000,
    "ApplicationName": "Windows Event Viewer",
    "Collection": "windows-events",
    "CollectionMap": {
      "System": "windows-eventlog-system",
      "Application": "windows-eventlog-application",
      "Security": "windows-eventlog-security"
    },
    "Labels": [ "event-viewer", "windows" ],
    "IncludeXmlDetails": false,
    "FilterConditions": null,
    "IncludeSources": [],
    "ExcludeSources": []
  }
}
