<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:edit="https://github.com/avaloniaui/avaloniaedit"
             x:Class="com.logdb.windows.collector.ui.Views.Pages.AdvancedPageView">
    <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
        <TextBlock TextWrapping="Wrap"
                   Foreground="{DynamicResource WarningTextBrushTheme}"
                   Text="Last resort: use this page only for advanced troubleshooting. Standard configuration should be done from Data Sources and Destination." />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Content="Reset to Current"
                    Command="{Binding ResetEditorCommand}"
                    ToolTip.Tip="Discard your edits and reload the editor from the live config." />
            <Button Classes="accent-success"
                    Command="{Binding ApplyJsonCommand}"
                    ToolTip.Tip="Validate and push the editor JSON to the running collector. If the API key field is blank, the existing key is kept."
                    MinWidth="150">
                <Panel>
                    <TextBlock Text="Apply Changes" VerticalAlignment="Center" HorizontalAlignment="Center"
                               IsVisible="{Binding !ApplyJsonCommand.IsRunning}" />
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center"
                                IsVisible="{Binding ApplyJsonCommand.IsRunning}">
                        <ProgressBar IsIndeterminate="True" Width="40" Height="3" VerticalAlignment="Center" />
                        <TextBlock Text="Applying…" VerticalAlignment="Center" />
                    </StackPanel>
                </Panel>
            </Button>
            <TextBlock VerticalAlignment="Center"
                       Classes="muted"
                       Text="The apiKey field is blanked on load for safety. Leave it blank to keep the current key; type a new value to change it." />
        </StackPanel>

        <TextBlock Grid.Row="2"
                   Text="{Binding JsonValidationMessage}"
                   Foreground="{DynamicResource SecondaryTextBrushTheme}" />

        <Border Grid.Row="3" Classes="panel" Padding="0">
            <edit:TextEditor x:Name="JsonEditor"
                             FontFamily="Consolas, Menlo, 'Courier New', monospace"
                             FontSize="13"
                             ShowLineNumbers="True"
                             WordWrap="False"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource SurfaceBrush}"
                             Foreground="{DynamicResource PrimaryTextBrushTheme}" />
        </Border>
    </Grid>
</UserControl>
