<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="com.logdb.windows.collector.ui.Views.Pages.DestinationPageView">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="10">
        <Border Classes="panel">
            <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                <TextBlock Text="API Key" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <TextBlock VerticalAlignment="Center"
                               Text="{Binding ApiKeyStatusText}" />
                    <TextBlock VerticalAlignment="Center"
                               Text="{Binding CustomerName, StringFormat='(owner: {0})'}"
                               Classes="muted"
                               IsVisible="{Binding HasCustomerName}" />
                    <Button Content="Replace Key"
                            Command="{Binding ReplaceApiKeyCommand}"
                            IsVisible="{Binding ShowReplaceApiKeyAction}" />
                    <Button Command="{Binding SaveApiKeyCommand}"
                            IsVisible="{Binding IsReplacingApiKey}"
                            MinWidth="110">
                        <Panel>
                            <TextBlock Text="Save Key" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       IsVisible="{Binding !SaveApiKeyCommand.IsRunning}" />
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center"
                                        IsVisible="{Binding SaveApiKeyCommand.IsRunning}">
                                <ProgressBar IsIndeterminate="True" Width="40" Height="3" VerticalAlignment="Center" />
                                <TextBlock Text="Saving…" VerticalAlignment="Center" />
                            </StackPanel>
                        </Panel>
                    </Button>
                    <Button Content="Cancel Replace"
                            Command="{Binding CancelReplaceApiKeyCommand}"
                            IsVisible="{Binding IsReplacingApiKey}" />
                </StackPanel>

                <TextBlock Grid.Row="1"
                           Text="New Key"
                           VerticalAlignment="Center"
                           IsVisible="{Binding IsReplacingApiKey}" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         PasswordChar="*"
                         Watermark="Paste new API key"
                         IsVisible="{Binding IsReplacingApiKey}"
                         Text="{Binding NewApiKey}" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="panel">
            <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,Auto" RowSpacing="10" ColumnSpacing="8">
                <TextBlock Text="Resolved Endpoint" VerticalAlignment="Top" Margin="0,4,0,0" />
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="{Binding ResolvedEndpointDisplay}"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"
                               IsEnabled="False" />
                    <TextBlock Classes="muted"
                               TextWrapping="Wrap"
                               Text="Auto-resolved from the LogDB discovery service using your API key. Read-only. To override (self-hosted deployments, networks where discovery is unreachable), edit the raw config on the Advanced page." />
                </StackPanel>

                <TextBlock Grid.Row="1" Text="Protocol" VerticalAlignment="Top" Margin="0,6,0,0" />
                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                    <ComboBox HorizontalAlignment="Stretch"
                              ItemsSource="{Binding ProtocolOptions}"
                              SelectedItem="{Binding Protocol}" />
                    <TextBlock Classes="muted"
                               TextWrapping="Wrap"
                               Text="Transport used to send logs to LogDB. Native (gRPC) is the default and recommended option — fastest and most efficient. Use REST only when gRPC is blocked by a corporate firewall or proxy. OpenTelemetry is for forwarding to an OTLP-compatible collector instead of LogDB directly." />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <Button Command="{Binding SaveCommand}"
                    IsEnabled="{Binding CanSaveDestinationSettings}"
                    MinWidth="200">
                <Panel>
                    <TextBlock Text="Save Destination Settings" VerticalAlignment="Center" HorizontalAlignment="Center"
                               IsVisible="{Binding !SaveCommand.IsRunning}" />
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center"
                                IsVisible="{Binding SaveCommand.IsRunning}">
                        <ProgressBar IsIndeterminate="True" Width="40" Height="3" VerticalAlignment="Center" />
                        <TextBlock Text="Saving…" VerticalAlignment="Center" />
                    </StackPanel>
                </Panel>
            </Button>
            <Button Command="{Binding TestConnectionCommand}" MinWidth="160">
                <Panel>
                    <TextBlock Text="Test Connection"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               IsVisible="{Binding !TestConnectionCommand.IsRunning}" />
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                IsVisible="{Binding TestConnectionCommand.IsRunning}">
                        <ProgressBar IsIndeterminate="True"
                                     Width="50"
                                     Height="3"
                                     VerticalAlignment="Center" />
                        <TextBlock Text="Testing…" VerticalAlignment="Center" />
                    </StackPanel>
                </Panel>
            </Button>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="{Binding ValidationMessage}" Foreground="{DynamicResource SecondaryTextBrushTheme}" />
    </Grid>
</UserControl>
