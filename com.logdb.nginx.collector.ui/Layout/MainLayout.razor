@inherits LayoutComponentBase
@inject IHttpClientFactory HttpClientFactory

<div class="page">
    <div class="sidebar">
        <div class="top-row">
            <div class="logo-area">
                <a href="" class="logo-link">
                    <img src="assets/logo-full.svg" alt="LogDB Logo" class="logo-img" />
                    <span class="logo-subtitle">NGINX</span>
                </a>
            </div>
            <div class="sidebar-controls">
                <button class="sidebar-control-btn" type="button" onclick="toggleTheme(); return false;" title="Toggle theme">
                    <i class="bi bi-sun-fill"></i>
                </button>
            </div>
        </div>

        <div class="nav-scrollable">
            <nav class="nav flex-column">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <i class="bi bi-speedometer2 me-2"></i> Dashboard
                    </NavLink>
                </div>

                <div class="nav-item px-3 pt-3">
                    <h6 class="nav-section-title">Sources</h6>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="pipeline">
                        <i class="bi bi-diagram-3 me-2"></i> Pipeline
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="targets">
                        <i class="bi bi-collection me-2"></i> Targets
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="console">
                        <i class="bi bi-terminal me-2"></i> Live Console
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="traffic">
                        <i class="bi bi-activity me-2"></i> Traffic
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="filters">
                        <i class="bi bi-funnel me-2"></i> Filters
                    </NavLink>
                </div>

                <div class="nav-item px-3 pt-3">
                    <h6 class="nav-section-title">Storage</h6>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="spool">
                        <i class="bi bi-hdd-stack me-2"></i> Spool
                    </NavLink>
                </div>

                <div class="nav-item px-3 pt-3">
                    <h6 class="nav-section-title">Delivery</h6>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="exporter-console">
                        <i class="bi bi-cloud-upload me-2"></i> Exporter Console
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="sent-records">
                        <i class="bi bi-send-check me-2"></i> Sent Records
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="activity">
                        <i class="bi bi-bar-chart-line me-2"></i> Activity
                    </NavLink>
                </div>

                @if (_portalUrl is not null)
                {
                <div class="nav-item px-3 pt-3">
                    <h6 class="nav-section-title">Systems</h6>
                </div>

                <div class="nav-item px-3">
                    <a class="nav-link" href="@($"{_portalUrl}/account/")" target="_blank" rel="noopener noreferrer">
                        <i class="bi bi-people me-2"></i> Account
                    </a>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="@($"{_portalUrl}/ai/")" target="_blank" rel="noopener noreferrer">
                        <i class="bi bi-cpu me-2"></i> AI
                    </a>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="@($"{_portalUrl}/auth/")" target="_blank" rel="noopener noreferrer">
                        <i class="bi bi-shield-lock me-2"></i> Auth
                    </a>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="@($"{_portalUrl}/backup/")" target="_blank" rel="noopener noreferrer">
                        <i class="bi bi-cloud-download me-2"></i> Backup
                    </a>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="@($"{_portalUrl}/billing/")" target="_blank" rel="noopener noreferrer">
                        <i class="bi bi-credit-card me-2"></i> Billing
                    </a>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="@($"{_portalUrl}/docker-collector/")" target="_blank" rel="noopener noreferrer">
                        <i class="bi bi-cloud-arrow-up me-2"></i> Docker Collector
                    </a>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="@($"{_portalUrl}/hash/")" target="_blank" rel="noopener noreferrer">
                        <i class="bi bi-shield-check me-2"></i> Hash
                    </a>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="@($"{_portalUrl}/kafka/")" target="_blank" rel="noopener noreferrer">
                        <i class="bi bi-hdd-stack me-2"></i> Kafka
                    </a>
                </div>
                <div class="nav-item px-3">
                    <a class="nav-link" href="@($"{_portalUrl}/monitor/")" target="_blank" rel="noopener noreferrer">
                        <i class="bi bi-display me-2"></i> Monitor
                    </a>
                </div>
                }
            </nav>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="sidebar-footer">
                    <span class="sidebar-user" title="Signed in user">
                        <i class="bi bi-person-circle me-2"></i>@context.User.Identity?.Name
                    </span>
                    <form method="post" action="logout">
                        <button class="sidebar-logout-btn" type="submit" title="Sign out">
                            <i class="bi bi-box-arrow-right me-1"></i> Sign out
                        </button>
                    </form>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private string? _portalUrl;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("NginxCollectorApi");
            var response = await client.GetFromJsonAsync<PortalDiscoveryResult>("api/discovery/portal");
            _portalUrl = response?.PortalUrl;
        }
        catch { /* Discovery unavailable - Systems section hidden */ }
    }

    private record PortalDiscoveryResult(string? PortalUrl);
}
