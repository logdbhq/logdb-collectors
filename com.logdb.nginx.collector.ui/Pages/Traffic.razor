        ) !important;
    }

    .count-badge {
        font-size: 0.72rem;
        font-weight: 600;
        padding: 0.15em 0.4em;
    }

    .blocked-icon {
        color: #e5534b;
        font-size: 0.75rem;
    }

    .blocked-indicator {
        color: #e5534b;
        font-size: 0.78rem;
        font-weight: 500;
    }

    .blocked-tag {
        background: var(--danger-muted) !important;
        border: 1px solid var(--danger-color) !important;
        color: var(--danger-color) !important;
        font-size: 0.82rem;
        padding: 0.35em 0.6em;
        font-weight: normal;
    }

    .blocked-tag code {
        color: inherit;
        font-size: 0.82rem;
    }

    .exclusion-remove {
        font-size: 0.5rem;
        padding: 0.15em;
        margin-left: 0.2em;
        opacity: 0.7;
        cursor: pointer;
    }

    .exclusion-remove:hover {
        opacity: 1;
    }

    .traffic-row {
        cursor: pointer;
    }

    .traffic-row:active {
        opacity: 0.8;
    }

    .payload-chevron {
        font-size: 0.65rem;
        margin-right: 4px;
        opacity: 0.5;
        vertical-align: middle;
