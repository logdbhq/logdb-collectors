@page "/traffic"
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@implements IDisposable

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="page-title mb-0"><i class="bi bi-activity me-2"></i>Traffic</h4>
    <div class="d-flex align-items-center gap-2">
        <div class="input-group input-group-sm" style="width: 200px;">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" placeholder="Filter path/IP..." @bind="_filter" @bind:event="oninput" />
        </div>
        <select class="form-select form-select-sm" style="width: 80px;" @bind="_logTypeFilter">
            <option value="">All</option>
            <option value="access">Access</option>
            <option value="error">Error</option>
        </select>
        <select class="form-select form-select-sm" style="width: 80px;" @bind="_maxLines">
            <option value="100">100</option>
            <option value="200">200</option>
            <option value="500">500</option>
        </select>
        <div class="btn-group btn-group-sm">
            <button class="btn btn-outline-primary" @onclick="LoadAsync" title="Refresh now">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
            <button class="btn @(_autoRefresh ? "btn-primary" : "btn-outline-secondary")" @onclick="ToggleAutoRefresh" title="@(_autoRefresh ? "Auto-refresh ON (5s)" : "Auto-refresh OFF")">
                <i class="bi bi-arrow-repeat"></i>
            </button>
        </div>
        <span class="refresh-indicator"><span class="refresh-dot @(_autoRefresh ? "" : "paused")"></span> @(_autoRefresh ? "5s" : "Manual")</span>
    </div>
</div>

@if (_connectError is not null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>@_connectError</div>
}

<div class="traffic-info mb-2">
    <span class="text-muted" style="font-size: 0.8rem;">
        <i class="bi bi-info-circle me-1"></i>Shows raw log file entries (unfiltered) - use this to identify paths/IPs to exclude from export.
        <span class="blocked-indicator ms-2"><i class="bi bi-funnel-fill"></i> Blocked</span> = excluded from export pipeline.
    </span>
</div>

@* Active Exclusions *@
@if (_rules is not null && (_rules.ExcludePaths.Count > 0 || _rules.ExcludeRemoteAddresses.Count > 0))
{
    <div class="card mb-3">
        <div class="card-header py-2 px-3 d-flex justify-content-between align-items-center">
            <span class="card-title-label"><i class="bi bi-funnel-fill me-1"></i> Active Exclusions</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showExclusions = !_showExclusions">
                <i class="bi @(_showExclusions ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </button>
        </div>
        @if (_showExclusions)
        {
            <div class="card-body p-3">
                @if (_rules.ExcludePaths.Count > 0)
                {
                    <div class="mb-2"><strong style="font-size: 0.82rem;">Paths:</strong></div>
                    <div class="d-flex flex-wrap gap-2 mb-3">
                        @foreach (var path in _rules.ExcludePaths)
                        {
                            var p = path;
                            <span class="badge blocked-tag d-flex align-items-center gap-1">
                                <i class="bi bi-funnel-fill"></i>
                                <code>@p</code>
                                <button class="btn-close btn-close-white exclusion-remove" @onclick="() => UnblockPath(p)" disabled="@_excludeSaving" title="Unblock"></button>
                            </span>
                        }
                    </div>
                }
                @if (_rules.ExcludeRemoteAddresses.Count > 0)
                {
                    <div class="mb-2"><strong style="font-size: 0.82rem;">IPs:</strong></div>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var ip in _rules.ExcludeRemoteAddresses)
                        {
                            var addr = ip;
                            <span class="badge blocked-tag d-flex align-items-center gap-1">
                                <i class="bi bi-funnel-fill"></i>
                                <code>@addr</code>
                                <button class="btn-close btn-close-white exclusion-remove" @onclick="() => UnblockIp(addr)" disabled="@_excludeSaving" title="Unblock"></button>
                            </span>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

@* Path frequency summary *@
@if (_records.Count > 0)
{
    <div class="card mb-3">
        <div class="card-header py-2 px-3 d-flex justify-content-between align-items-center">
            <span class="card-title-label"><i class="bi bi-bar-chart me-1"></i> Top Paths</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showTopPaths = !_showTopPaths">
                <i class="bi @(_showTopPaths ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </button>
        </div>
        @if (_showTopPaths)
        {
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th style="width: 30px;"></th>
                            <th>Path</th>
                            <th class="text-end" style="width: 70px;">Count</th>
                            <th class="text-end" style="width: 50px;">%</th>
                            <th style="width: 90px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var g in GetTopPaths())
                        {
                            var pathPrefix = g.Path;
                            var blocked = IsPathBlocked(g.Path);
                            <tr class="@(blocked ? "row-blocked" : "")">
                                <td class="text-center">
                                    @if (blocked)
                                    {
                                        <i class="bi bi-funnel-fill blocked-icon" title="Excluded from export"></i>
                                    }
                                </td>
                                <td><code style="font-size: 0.82rem;">@g.Path</code></td>
                                <td class="text-end">@g.Count</td>
                                <td class="text-end">@g.Percent.ToString("F0")%</td>
                                <td class="text-end">
                                    @if (!blocked)
                                    {
                                        <button class="btn btn-outline-warning btn-sm py-0 px-1" style="font-size: 0.75rem;"
                                                @onclick="() => ConfirmExcludePath(pathPrefix)" disabled="@_excludeSaving"
                                                title="Add to path exclusions">
                                            <i class="bi bi-funnel"></i> Exclude
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-success btn-sm py-0 px-1" style="font-size: 0.75rem;"
                                                @onclick="() => UnblockPath(pathPrefix)" disabled="@_excludeSaving"
                                                title="Remove from exclusions">
                                            <i class="bi bi-check-lg"></i> Unblock
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="card mb-3">
        <div class="card-header py-2 px-3 d-flex justify-content-between align-items-center">
            <span class="card-title-label"><i class="bi bi-geo-alt me-1"></i> Top IPs</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showTopIps = !_showTopIps">
                <i class="bi @(_showTopIps ? "bi-chevron-up" : "bi-chevron-down")"></i>
            </button>
        </div>
        @if (_showTopIps)
        {
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th style="width: 30px;"></th>
                            <th>Remote Address</th>
                            <th class="text-end" style="width: 70px;">Count</th>
                            <th class="text-end" style="width: 50px;">%</th>
                            <th style="width: 90px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var g in GetTopIps())
                        {
                            var ip = g.Ip;
                            var blocked = IsIpBlocked(g.Ip);
                            <tr class="@(blocked ? "row-blocked" : "")">
                                <td class="text-center">
                                    @if (blocked)
                                    {
                                        <i class="bi bi-funnel-fill blocked-icon" title="Excluded from export"></i>
                                    }
                                </td>
                                <td><code style="font-size: 0.82rem;">@g.Ip</code></td>
                                <td class="text-end">@g.Count</td>
                                <td class="text-end">@g.Percent.ToString("F0")%</td>
                                <td class="text-end">
                                    @if (!blocked)
                                    {
                                        <button class="btn btn-outline-warning btn-sm py-0 px-1" style="font-size: 0.75rem;"
                                                @onclick="() => ConfirmExcludeIp(ip)" disabled="@_excludeSaving"
                                                title="Add to IP exclusions">
                                            <i class="bi bi-funnel"></i> Exclude
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-success btn-sm py-0 px-1" style="font-size: 0.75rem;"
                                                @onclick="() => UnblockIp(ip)" disabled="@_excludeSaving"
                                                title="Remove from exclusions">
                                            <i class="bi bi-check-lg"></i> Unblock
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@* Log entries *@
<div class="card">
    <div class="card-header py-2 px-3">
        <span class="card-title-label"><i class="bi bi-list-ul me-1"></i> Recent Entries</span>
        <span class="badge bg-secondary ms-2">@GroupedRecords.Count entries</span>
        @if (GroupedRecords.Any(g => g.Count > 1))
        {
            <span class="badge bg-info ms-1" title="Records grouped by second + method + path + status + IP">grouped</span>
        }
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0 traffic-table">
                <thead class="sticky-top">
                    <tr>
                        <th style="width: 25px;"></th>
                        <th style="width: 80px;">Time</th>
                        <th style="width: 55px;">Type</th>
                        <th style="width: 40px;">Cnt</th>
                        <th style="width: 50px;">Method</th>
                        <th style="width: 45px;">Status</th>
                        <th>Path / Message</th>
                        <th style="width: 120px;">Remote IP</th>
                        <th style="width: 65px;">Bytes</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var rowIdx = 0; }
                    @foreach (var g in GroupedRecords)
                    {
                        var r = g.Record;
                        var idx = rowIdx++;
                        var isError = r.LogType == 1 || r.StatusCode >= 500;
                        var isWarn = r.StatusCode >= 400 && r.StatusCode < 500;
                        var blocked = IsRecordBlocked(r);
                        var expanded = _expandedRows.Contains(idx);
                        <tr class="traffic-row @(blocked ? "row-blocked" : isError ? "table-danger" : isWarn ? "table-warning" : "")" @onclick="() => ToggleRow(idx)">
                            <td class="text-center">
                                @if (blocked)
                                {
                                    <i class="bi bi-funnel-fill blocked-icon" title="Excluded from export"></i>
                                }
                            </td>
                            <td class="text-muted" style="font-size: 0.78rem;">@r.Timestamp.ToString("HH:mm:ss")</td>
                            <td>
                                @if (r.LogType == 0)
                                {
                                    <span class="badge bg-info" style="font-size: 0.7rem;">ACC</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger" style="font-size: 0.7rem;">ERR</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (g.Count > 1)
                                {
                                    <span class="badge bg-secondary count-badge" title="@g.Count identical records">x@g.Count</span>
                                }
                            </td>
                            <td style="font-size: 0.82rem; font-weight: 500;">@(r.Method ?? "")</td>
                            <td>
                                @if (r.StatusCode is not null)
                                {
                                    <span class="@StatusClass(r.StatusCode)" style="font-size: 0.82rem; font-weight: 500;">@r.StatusCode</span>
                                }
                            </td>
                            <td style="font-size: 0.82rem; max-width: 400px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@(r.Path ?? r.Message)">
                                <i class="bi @(expanded ? "bi-chevron-down" : "bi-chevron-right") payload-chevron"></i>
                                @(r.Path ?? r.Message)
                            </td>
                            <td style="font-size: 0.78rem;" class="text-muted">@(r.RemoteAddress ?? "")</td>
                            <td style="font-size: 0.78rem;" class="text-muted text-end">@FormatBytes(g.TotalBytes)</td>
                        </tr>
                        @if (expanded)
                        {
                            <tr class="payload-row @(blocked ? "row-blocked" : "")">
                                <td colspan="9">
                                    <div class="payload-content">
                                        <pre class="payload-pre mb-0">@r.Message</pre>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
