            rgba(200, 0, 0, 0.04) 16px
        ) !important;
    }
</style>

@code {
    private List<TailRecordDto> _records = new();
    private FilterRulesDto? _rules;
    private string? _connectError;
    private Timer? _timer;
    private bool _autoRefresh = true;
    private string? _filter;
    private string? _logTypeFilter;
    private int _maxLines = 200;
    private bool _showTopPaths = true;
    private bool _showTopIps;
    private bool _showExclusions = true;
    private bool _excludeSaving;
    private HashSet<int> _expandedRows = new();

    private List<RecordGroup> GroupedRecords => AggregateRecords(FilteredRecords);

    private List<TailRecordDto> FilteredRecords =>
        _records.Where(r =>
        {
            if (!string.IsNullOrEmpty(_logTypeFilter))
            {
                var match = _logTypeFilter == "access" ? 0 : 1;
                if (r.LogType != match) return false;
            }
            if (!string.IsNullOrEmpty(_filter))
            {
                return (r.Path?.Contains(_filter, StringComparison.OrdinalIgnoreCase) == true) ||
                       (r.RemoteAddress?.Contains(_filter, StringComparison.OrdinalIgnoreCase) == true) ||
                       (r.Message?.Contains(_filter, StringComparison.OrdinalIgnoreCase) == true);
            }
            return true;
        }).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _timer = new Timer(async _ =>
        {
            if (_autoRefresh)
            {
                await LoadAsync();
                await InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task LoadAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("NginxCollectorApi");
            _records = await client.GetFromJsonAsync<List<TailRecordDto>>($"/api/tail/recent?lines={_maxLines}") ?? new();
            _rules = await client.GetFromJsonAsync<FilterRulesDto>("/api/filters");
            _connectError = null;
        }
        catch (Exception ex)
        {
            _connectError = ex.Message;
        }
    }

    private void ToggleAutoRefresh() => _autoRefresh = !_autoRefresh;

    private void ToggleRow(int idx)
    {
        if (!_expandedRows.Remove(idx))
            _expandedRows.Add(idx);
    }

    // --- Blocked detection ---

    private bool IsPathBlocked(string path)
    {
        if (_rules is null) return false;
        return _rules.ExcludePaths.Any(p => path.StartsWith(p, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsIpBlocked(string ip)
    {
        if (_rules is null) return false;
        return _rules.ExcludeRemoteAddresses.Any(a => a.Equals(ip, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsRecordBlocked(TailRecordDto r)
    {
        if (_rules is null || r.LogType != 0) return false; // error logs are never filtered
        if (r.Path is not null && IsPathBlocked(r.Path)) return true;
        if (r.RemoteAddress is not null && IsIpBlocked(r.RemoteAddress)) return true;
        return false;
    }

    // --- Top groups ---

    private List<PathGroup> GetTopPaths()
    {
        var accessRecords = _records.Where(r => r.LogType == 0 && r.Path is not null).ToList();
        if (accessRecords.Count == 0) return new();

        return accessRecords
            .GroupBy(r => NormalizePath(r.Path!))
            .Select(g => new PathGroup { Path = g.Key, Count = g.Count(), Percent = g.Count() * 100.0 / accessRecords.Count })
            .OrderByDescending(g => g.Count)
            .Take(15)
            .ToList();
    }

    private List<IpGroup> GetTopIps()
    {
        var accessRecords = _records.Where(r => r.LogType == 0 && r.RemoteAddress is not null).ToList();
        if (accessRecords.Count == 0) return new();

        return accessRecords
            .GroupBy(r => r.RemoteAddress!)
            .Select(g => new IpGroup { Ip = g.Key, Count = g.Count(), Percent = g.Count() * 100.0 / accessRecords.Count })
            .OrderByDescending(g => g.Count)
            .Take(15)
            .ToList();
    }

    private static string NormalizePath(string path)
    {
        var qIdx = path.IndexOf('?');
        var clean = qIdx >= 0 ? path[..qIdx] : path;

        var parts = clean.Split('/', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length <= 2) return clean;
        return "/" + string.Join("/", parts.Take(2));
    }

    // --- Exclude with confirm ---

    private async Task ConfirmExcludePath(string path)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Exclude path \"{path}\" from export pipeline?");
        if (!confirmed) return;
        await ExcludePath(path);
    }

    private async Task ConfirmExcludeIp(string ip)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Exclude IP \"{ip}\" from export pipeline?");
        if (!confirmed) return;
        await ExcludeIp(ip);
    }

    private async Task ExcludePath(string path)
    {
        if (_excludeSaving) return;
        _excludeSaving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("NginxCollectorApi");
            _rules = await (await client.PostAsJsonAsync("/api/filters/exclude-path", new { value = path }))
                .Content.ReadFromJsonAsync<FilterRulesDto>();
            _connectError = null;
        }
        catch (Exception ex) { _connectError = ex.Message; }
        finally { _excludeSaving = false; }
    }

    private async Task ExcludeIp(string ip)
    {
        if (_excludeSaving) return;
        _excludeSaving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("NginxCollectorApi");
            _rules = await (await client.PostAsJsonAsync("/api/filters/exclude-ip", new { value = ip }))
                .Content.ReadFromJsonAsync<FilterRulesDto>();
            _connectError = null;
        }
        catch (Exception ex) { _connectError = ex.Message; }
        finally { _excludeSaving = false; }
    }

    // --- Unblock ---

    private async Task UnblockPath(string path)
    {
        if (_excludeSaving) return;
        _excludeSaving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("NginxCollectorApi");
            var response = await client.DeleteAsync($"/api/filters/exclude-path?value={Uri.EscapeDataString(path)}");
            _rules = await response.Content.ReadFromJsonAsync<FilterRulesDto>();
            _connectError = null;
        }
        catch (Exception ex) { _connectError = ex.Message; }
        finally { _excludeSaving = false; }
    }

    private async Task UnblockIp(string ip)
    {
        if (_excludeSaving) return;
        _excludeSaving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("NginxCollectorApi");
            var response = await client.DeleteAsync($"/api/filters/exclude-ip?value={Uri.EscapeDataString(ip)}");
            _rules = await response.Content.ReadFromJsonAsync<FilterRulesDto>();
            _connectError = null;
        }
        catch (Exception ex) { _connectError = ex.Message; }
        finally { _excludeSaving = false; }
    }

    private static string StatusClass(int? code) => code switch
    {
        >= 500 => "text-danger",
        >= 400 => "text-warning",
        >= 300 => "text-info",
        _ => "text-success"
    };

    private static string FormatBytes(long? bytes) => bytes switch
    {
        null => "",
        < 1024 => $"{bytes}B",
        < 1_048_576 => $"{bytes / 1024.0:F0}K",
        _ => $"{bytes / 1_048_576.0:F1}M"
    };

    public void Dispose() => _timer?.Dispose();

    private class TailRecordDto
    {
        public DateTime Timestamp { get; set; }
        public string Message { get; set; } = "";
        public int LogType { get; set; }
        public string TargetName { get; set; } = "";
        public string? RemoteAddress { get; set; }
        public string? Method { get; set; }
        public string? Path { get; set; }
        public int? StatusCode { get; set; }
        public long? ResponseBytes { get; set; }
        public string? Severity { get; set; }
    }

    private class FilterRulesDto
    {
        public bool ExcludeStaticFiles { get; set; }
        public List<string> ExcludePaths { get; set; } = new();
        public List<string> ExcludeRemoteAddresses { get; set; } = new();
    }

    private static List<RecordGroup> AggregateRecords(List<TailRecordDto> records)
    {
        var result = new List<RecordGroup>();

        var groups = records.GroupBy(r => r.LogType == 0
            ? (object)(
                new DateTime(r.Timestamp.Year, r.Timestamp.Month, r.Timestamp.Day,
                    r.Timestamp.Hour, r.Timestamp.Minute, r.Timestamp.Second, r.Timestamp.Kind),
                r.Method ?? "",
                r.Path ?? "",
                r.StatusCode ?? 0,
                r.RemoteAddress ?? "")
            : (object)r // error logs: never aggregate, each is unique
        );

        foreach (var group in groups)
        {
            var items = group.ToList();
            var representative = items[0];
            var totalBytes = items.Where(r => r.ResponseBytes.HasValue).Sum(r => r.ResponseBytes!.Value);
            result.Add(new RecordGroup
            {
                Record = representative,
                Count = items.Count,
                TotalBytes = totalBytes > 0 ? totalBytes : representative.ResponseBytes
            });
        }

        return result;
    }

    private class RecordGroup
    {
        public TailRecordDto Record { get; set; } = null!;
        public int Count { get; set; }
        public long? TotalBytes { get; set; }
    }

    private class PathGroup
    {
        public string Path { get; set; } = "";
        public int Count { get; set; }
        public double Percent { get; set; }
    }

    private class IpGroup
    {
        public string Ip { get; set; } = "";
        public int Count { get; set; }
        public double Percent { get; set; }
    }
}
