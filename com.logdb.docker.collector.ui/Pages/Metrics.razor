@page "/metrics"
@inject IHttpClientFactory HttpClientFactory
@implements IDisposable

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="page-title mb-0"><i class="bi bi-activity me-2"></i>Live Metrics</h4>
    <div class="d-flex align-items-center gap-2">
        @if (_data is not null)
        {
            <span class="badge bg-info">@_data.ContainerCount containers</span>
            <span class="badge bg-secondary" title="Total collection cycles">@_data.TotalCollections cycles</span>
            <span class="badge @FreshnessClass"
                  title="Metrics only change when the collector runs a collection cycle (every @FormatInterval(_intervalSeconds)) — not on the page's @_refreshInterval s poll. This is the age of the data on screen.">
                <i class="bi bi-clock-history me-1"></i>collected @FormatTime(_data.LastCollectionUtc)
            </span>
        }
        <div class="btn-group btn-group-sm">
            <button class="btn @(_sortField == "cpu" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetSort("cpu")' title="Sort by CPU">CPU</button>
            <button class="btn @(_sortField == "mem" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetSort("mem")' title="Sort by Memory">MEM</button>
            <button class="btn @(_sortField == "net" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetSort("net")' title="Sort by Network">NET</button>
            <button class="btn @(_sortField == "name" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetSort("name")' title="Sort by Name">Name</button>
        </div>
        <div class="btn-group btn-group-sm">
            <button class="btn @(_paused ? "btn-warning" : "btn-outline-secondary")" @onclick="TogglePause" title="@(_paused ? "Resume" : "Pause")">
                <i class="bi @(_paused ? "bi-play-fill" : "bi-pause-fill")"></i>
            </button>
            <button class="btn btn-outline-secondary" @onclick="ManualRefresh" disabled="@_refreshing">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
        <div class="d-flex align-items-center gap-1" title="How often container metrics are collected and exported to LogDB">
            <i class="bi bi-clock-history text-muted"></i>
            <select class="form-select form-select-sm" style="width:auto;" value="@_intervalSeconds" @onchange="OnIntervalChanged" disabled="@_savingInterval">
                @foreach (var opt in IntervalOptions())
                {
                    <option value="@opt.Seconds">@opt.Label</option>
                }
            </select>
        </div>
        <span class="refresh-indicator" title="How often this page re-fetches from the backend. The underlying metrics still only change once per collection cycle.">
            <span class="refresh-dot @(_paused ? "paused" : "")"></span> @(_paused ? "Paused" : $"poll {_refreshInterval}s")
        </span>
    </div>
</div>

@if (_connectError is not null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>Unable to connect: @_connectError</div>
}
else if (_data is null)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"></div><p class="mt-2 text-muted">Loading metrics...</p></div>
}
else
{
    @* System Totals *@
    <div class="row g-3 mb-3">
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card h-100">
                <div class="card-body p-3 text-center">
                    <div class="stat-value @CpuColor(_data.TotalCpu)">@_data.TotalCpu.ToString("F1")%</div>
                    <div class="stat-label">Total CPU</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card h-100">
                <div class="card-body p-3 text-center">
                    <div class="stat-value">@FormatBytes(_data.TotalMemoryUsed)</div>
                    <div class="stat-label">Memory Used / @FormatBytes(_data.TotalMemoryLimit)</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card h-100">
                <div class="card-body p-3 text-center">
                    <div class="stat-value text-info">@FormatBytes(_data.TotalNetworkRx)</div>
                    <div class="stat-label"><i class="bi bi-arrow-down"></i> RX / <i class="bi bi-arrow-up"></i> @FormatBytes(_data.TotalNetworkTx) TX</div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card stat-card h-100">
                <div class="card-body p-3 text-center">
                    <div class="stat-value">@_data.ContainerCount</div>
                    <div class="stat-label">Containers · @FormatTime(_data.LastCollectionUtc)</div>
                </div>
            </div>
        </div>
    </div>

    @* Container Metrics Table *@
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center py-2 px-3">
            <span class="card-title-label"><i class="bi bi-cpu me-1"></i> Container Resources</span>
        </div>
        <div class="card-body p-0">
            @if (SortedContainers.Count == 0)
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-hourglass-split" style="font-size: 2rem; opacity: 0.3;"></i>
                    <div class="mt-2">Waiting for first metrics collection...</div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th style="width: 24px;"></th>
                                <th>Container</th>
                                <th>Image</th>
                                <th class="text-end" style="width: 100px;">CPU %</th>
                                <th style="width: 130px;">CPU</th>
                                <th class="text-end" style="width: 100px;">MEM %</th>
                                <th style="width: 130px;">Memory</th>
                                <th class="text-end">MEM Used</th>
                                <th class="text-end">NET RX</th>
                                <th class="text-end">NET TX</th>
                                <th class="text-end">DISK R</th>
                                <th class="text-end">DISK W</th>
                                <th class="text-end">PIDs</th>
                                <th class="text-center">Health</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in SortedContainers)
                            {
                                <tr class="@RowClass(c)">
                                    <td>
                                        <span class="metrics-state-dot @(c.ContainerState == "running" ? "running" : "stopped")" title="@c.ContainerState"></span>
                                    </td>
                                    <td>
                                        <div class="metrics-container-name" title="@c.ContainerId">@TruncName(c.ContainerName)</div>
                                        @if (!string.IsNullOrEmpty(c.ComposeService))
                                        {
                                            <div class="metrics-compose-info" title="@c.ComposeProject">@c.ComposeService</div>
                                        }
                                    </td>
                                    <td>
                                        <span class="metrics-image" title="@c.Image:@c.ImageTag">@TruncImage(c.Image)</span>
                                    </td>
                                    <td class="text-end">
                                        <span class="metrics-value @CpuColor(c.CpuUsagePercent)">@c.CpuUsagePercent.ToString("F1")%</span>
                                    </td>
                                    <td>
                                        <div class="metrics-bar-track">
                                            <div class="metrics-bar @CpuBarClass(c.CpuUsagePercent)" style="width: @(Math.Min(c.CpuUsagePercent, 100).ToString("F0"))%"></div>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <span class="metrics-value @MemColor(c.MemoryUsagePercent)">@c.MemoryUsagePercent.ToString("F1")%</span>
                                    </td>
                                    <td>
                                        <div class="metrics-bar-track">
                                            <div class="metrics-bar @MemBarClass(c.MemoryUsagePercent)" style="width: @(Math.Min(c.MemoryUsagePercent, 100).ToString("F0"))%"></div>
                                        </div>
                                    </td>
                                    <td class="text-end"><span class="metrics-bytes">@FormatBytes(c.MemoryUsageBytes) / @FormatBytes(c.MemoryLimitBytes)</span></td>
                                    <td class="text-end"><span class="metrics-bytes">@FormatBytes(c.NetworkRxBytes)</span></td>
                                    <td class="text-end"><span class="metrics-bytes">@FormatBytes(c.NetworkTxBytes)</span></td>
                                    <td class="text-end"><span class="metrics-bytes">@FormatBytes(c.BlockIoReadBytes)</span></td>
                                    <td class="text-end"><span class="metrics-bytes">@FormatBytes(c.BlockIoWriteBytes)</span></td>
                                    <td class="text-end">@c.PidsCurrent</td>
                                    <td class="text-center">
                                        @if (c.HealthStatus is not null)
                                        {
                                            <span class="badge @HealthBadge(c.HealthStatus)">@c.HealthStatus</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                        @if (c.RestartCount > 0)
                                        {
                                            <span class="badge bg-warning ms-1" title="Restart count">@c.RestartCount <i class="bi bi-arrow-repeat"></i></span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

<style>
    .metrics-state-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--text-muted);
    }

    .metrics-state-dot.running {
        background: var(--success-color);
        box-shadow: 0 0 6px var(--success-color);
        animation: pulse-dot 2s infinite;
    }

    .metrics-state-dot.stopped {
        background: var(--danger-color);
    }

    .metrics-container-name {
        font-weight: 600;
        font-size: 0.88rem;
        color: var(--accent-blue);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 180px;
    }

    .metrics-compose-info {
        font-size: 0.72rem;
        color: var(--text-muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 180px;
    }

    .metrics-image {
        font-size: 0.8rem;
        color: var(--text-secondary);
        font-family: 'Cascadia Code', 'Fira Code', monospace;
    }

    .metrics-value {
        font-weight: 600;
        font-size: 0.88rem;
        font-family: 'Cascadia Code', 'Fira Code', monospace;
    }

    .metrics-bytes {
        font-size: 0.8rem;
        color: var(--text-secondary);
        font-family: 'Cascadia Code', 'Fira Code', monospace;
    }

    /* Mini progress bars for CPU/MEM */
    .metrics-bar-track {
        width: 100%;
        height: 6px;
        background: var(--glass-bg-light);
        border-radius: 3px;
        border: 1px solid var(--border-color);
        overflow: hidden;
    }

    .metrics-bar {
        height: 100%;
        border-radius: 3px;
        transition: width 0.6s ease;
    }

    .metrics-bar.bar-ok { background: var(--success-color); }
    .metrics-bar.bar-warn { background: var(--warning-color); }
    .metrics-bar.bar-crit { background: var(--danger-color); }

    /* Row highlighting for high resource usage */
    tr.row-danger {
        background: var(--row-danger) !important;
    }

    tr.row-warning {
        background: var(--row-warning) !important;
    }

    tr.row-caution {
        background: var(--row-caution) !important;
    }

    .refresh-dot.paused {
        background: #d29922 !important;
        animation: none !important;
    }
</style>

@code {
    private LiveMetricsDto? _data;
    private string? _connectError;
    private Timer? _timer;
    private bool _paused;
    private bool _refreshing;
    private string _sortField = "cpu";
    private int _refreshInterval = 5;

    // Export/collection interval (distinct from the page's UI refresh rate above)
    private int _intervalSeconds = 300;
    private bool _savingInterval;

    // Colour the data-age badge by how overdue a collection is: green while fresh,
    // amber once we're past the interval, red once a cycle looks missed.
    private string FreshnessClass
    {
        get
        {
            if (_data?.LastCollectionUtc is null) return "bg-secondary";
            var age = (DateTime.UtcNow - _data.LastCollectionUtc.Value).TotalSeconds;
            if (age > _intervalSeconds * 1.5 + 10) return "bg-danger";
            if (age > _intervalSeconds + 5) return "bg-warning text-dark";
            return "bg-success";
        }
    }

    private List<ContainerMetricDto> SortedContainers
    {
        get
        {
            if (_data?.Containers is null) return new();
            var list = _data.Containers.ToList();
            return _sortField switch
            {
                "cpu" => list.OrderByDescending(c => c.CpuUsagePercent).ToList(),
                "mem" => list.OrderByDescending(c => c.MemoryUsagePercent).ToList(),
                "net" => list.OrderByDescending(c => c.NetworkRxBytes + c.NetworkTxBytes).ToList(),
                "name" => list.OrderBy(c => c.ContainerName).ToList(),
                _ => list
            };
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
        await LoadAsync();
        StartTimer();
    }

    private record IntervalOption(int Seconds, string Label);

    private IEnumerable<IntervalOption> IntervalOptions()
    {
        var presets = new List<IntervalOption>
        {
            new(30, "30 sec"),
            new(60, "1 min"),
            new(300, "5 min"),
            new(600, "10 min"),
            new(900, "15 min"),
            new(1800, "30 min"),
            new(3600, "1 hour"),
        };
        // Surface a non-preset value (e.g. set via env/config) so the dropdown reflects it
        if (presets.All(p => p.Seconds != _intervalSeconds))
            presets.Add(new IntervalOption(_intervalSeconds, FormatInterval(_intervalSeconds)));
        return presets.OrderBy(p => p.Seconds);
    }

    private static string FormatInterval(int seconds) =>
        seconds < 60 ? $"{seconds} sec"
        : seconds % 3600 == 0 ? $"{seconds / 3600} hour"
        : seconds % 60 == 0 ? $"{seconds / 60} min"
        : $"{seconds} sec";

    private async Task LoadSettingsAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("DockerCollectorApi");
            var settings = await client.GetFromJsonAsync<MetricsSettingsDto>("/api/metrics/settings");
            if (settings is not null) _intervalSeconds = settings.IntervalSeconds;
        }
        catch
        {
            // Leave default; the live-metrics fetch will surface any connection error.
        }
    }

    private async Task OnIntervalChanged(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var seconds)) return;

        _savingInterval = true;
        try
        {
            var client = HttpClientFactory.CreateClient("DockerCollectorApi");
            var response = await client.PostAsJsonAsync("/api/metrics/settings", new { intervalSeconds = seconds });
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<MetricsSettingsDto>();
                _intervalSeconds = result?.IntervalSeconds ?? seconds;
            }
        }
        catch
        {
            // Keep the previously loaded value on failure.
        }
        finally
        {
            _savingInterval = false;
        }
    }

    private void StartTimer()
    {
        _timer?.Dispose();
        _timer = new Timer(async _ =>
        {
            if (!_paused)
            {
                await LoadAsync();
                await InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.FromSeconds(_refreshInterval), TimeSpan.FromSeconds(_refreshInterval));
    }

    private async Task LoadAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("DockerCollectorApi");
            _data = await client.GetFromJsonAsync<LiveMetricsDto>("/api/metrics/live");
            _connectError = null;
        }
        catch (Exception ex)
        {
            _connectError = ex.Message;
        }
    }

    private async Task ManualRefresh()
    {
        _refreshing = true;
        await LoadAsync();
        _refreshing = false;
    }

    private void TogglePause() => _paused = !_paused;

    private void SetSort(string field) => _sortField = field;

    private static string TruncName(string name) =>
        name.Length <= 24 ? name : name[..21] + "...";

    private static string TruncImage(string image)
    {
        // Strip registry prefix if present
        var lastSlash = image.LastIndexOf('/');
        var shortName = lastSlash >= 0 ? image[(lastSlash + 1)..] : image;
        return shortName.Length <= 28 ? shortName : shortName[..25] + "...";
    }

    private static string CpuColor(double pct) => pct switch
    {
        >= 90 => "text-danger",
        >= 70 => "text-warning",
        _ => ""
    };

    private static string MemColor(double pct) => pct switch
    {
        >= 90 => "text-danger",
        >= 80 => "text-warning",
        _ => ""
    };

    private static string CpuBarClass(double pct) => pct switch
    {
        >= 90 => "bar-crit",
        >= 70 => "bar-warn",
        _ => "bar-ok"
    };

    private static string MemBarClass(double pct) => pct switch
    {
        >= 90 => "bar-crit",
        >= 80 => "bar-warn",
        _ => "bar-ok"
    };

    private static string RowClass(ContainerMetricDto c)
    {
        if (c.CpuUsagePercent >= 95 || c.MemoryUsagePercent >= 95) return "row-danger";
        if (c.CpuUsagePercent >= 80 || c.MemoryUsagePercent >= 85) return "row-warning";
        if (c.CpuUsagePercent >= 60 || c.MemoryUsagePercent >= 70) return "row-caution";
        return "";
    }

    private static string HealthBadge(string status) => status switch
    {
        "healthy" => "bg-success",
        "unhealthy" => "bg-danger",
        "starting" => "bg-warning",
        _ => "bg-secondary"
    };

    private static string FormatTime(DateTime? utc)
    {
        if (utc is null) return "-";
        var ago = DateTime.UtcNow - utc.Value;
        if (ago.TotalSeconds < 10) return "just now";
        if (ago.TotalSeconds < 60) return $"{(int)ago.TotalSeconds}s ago";
        return $"{(int)ago.TotalMinutes}m {ago.Seconds}s ago";
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1_048_576) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1_073_741_824) return $"{bytes / 1_048_576.0:F1} MB";
        return $"{bytes / 1_073_741_824.0:F2} GB";
    }

    public void Dispose() => _timer?.Dispose();

    // DTOs
    private class MetricsSettingsDto
    {
        public int IntervalSeconds { get; set; }
    }

    private class LiveMetricsDto
    {
        public List<ContainerMetricDto> Containers { get; set; } = new();
        public double TotalCpu { get; set; }
        public long TotalMemoryUsed { get; set; }
        public long TotalMemoryLimit { get; set; }
        public long TotalNetworkRx { get; set; }
        public long TotalNetworkTx { get; set; }
        public int ContainerCount { get; set; }
        public DateTime? LastCollectionUtc { get; set; }
        public long TotalCollections { get; set; }
    }

    private class ContainerMetricDto
    {
        public string ContainerId { get; set; } = "";
        public string ContainerName { get; set; } = "";
        public string Image { get; set; } = "";
        public string ImageTag { get; set; } = "";
        public string ContainerState { get; set; } = "";
        public string ContainerStatus { get; set; } = "";
        public string? ComposeProject { get; set; }
        public string? ComposeService { get; set; }
        public double CpuUsagePercent { get; set; }
        public int CpuOnlineCpus { get; set; }
        public long MemoryUsageBytes { get; set; }
        public long MemoryLimitBytes { get; set; }
        public double MemoryUsagePercent { get; set; }
        public long NetworkRxBytes { get; set; }
        public long NetworkTxBytes { get; set; }
        public long BlockIoReadBytes { get; set; }
        public long BlockIoWriteBytes { get; set; }
        public int PidsCurrent { get; set; }
        public string? HealthStatus { get; set; }
        public int RestartCount { get; set; }
        public DateTime Timestamp { get; set; }
    }
}
