@page "/diagnostics"
@inject IHttpClientFactory HttpClientFactory
@implements IDisposable

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="page-title mb-0">Diagnostics</h4>
    <div class="d-flex align-items-center gap-3">
        <button class="btn btn-outline-secondary btn-sm" @onclick="ManualRefresh" disabled="@_refreshing">
            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
        </button>
        <span class="refresh-indicator"><span class="refresh-dot"></span> Auto-refresh 10s</span>
    </div>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>@_error</div>
}
else if (_readiness is null)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-xl-4 col-md-6">
            <div class="card stat-card">
                <div class="card-header d-flex justify-content-between align-items-center py-2 px-3">
                    <span class="card-title-label"><i class="bi bi-heart-pulse me-1"></i> Readiness</span>
                    <span class="badge @(_readiness.Ready ? "bg-success" : "bg-danger")">@(_readiness.Ready ? "Ready" : "Not Ready")</span>
                </div>
                <div class="card-body p-3">
                    <div class="detail-row"><span class="detail-label">Health endpoint</span><span class="detail-value"><code>/health/ready</code></span></div>
                    <div class="detail-row"><span class="detail-label">Status code</span><span class="detail-value @(_readiness.Ready ? "text-success" : "text-danger")">@(_readiness.Ready ? "200" : "503")</span></div>
                </div>
            </div>
        </div>
    </div>

    @if (_readiness.Errors.Count > 0)
    {
        <h6 class="mb-2" style="color: var(--text-secondary);">Errors</h6>
        @foreach (var e in _readiness.Errors)
        {
            <div class="alert alert-danger py-2"><i class="bi bi-x-circle-fill me-2"></i>@e</div>
        }
    }

    @if (_readiness.Warnings.Count > 0)
    {
        <h6 class="mb-2 mt-3" style="color: var(--text-secondary);">Warnings</h6>
        @foreach (var w in _readiness.Warnings)
        {
            <div class="alert alert-warning py-2"><i class="bi bi-exclamation-circle-fill me-2"></i>@w</div>
        }
    }

    @if (_readiness.Errors.Count == 0 && _readiness.Warnings.Count == 0)
    {
        <div class="alert alert-success py-2"><i class="bi bi-check-circle-fill me-2"></i>No issues detected. All systems operational.</div>
    }
}

@code {
    private ReadinessDto? _readiness;
    private string? _error;
    private Timer? _timer;
    private bool _refreshing;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _timer = new Timer(async _ =>
        {
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(10), TimeSpan.FromSeconds(10));
    }

    private async Task ManualRefresh()
    {
        _refreshing = true;
        await LoadAsync();
        _refreshing = false;
    }

    private async Task LoadAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("DockerCollectorApi");
            var response = await client.GetAsync("/health/ready");
            _readiness = await response.Content.ReadFromJsonAsync<ReadinessDto>();
            _error = null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    public void Dispose() => _timer?.Dispose();

    private class ReadinessDto
    {
        public bool Ready { get; set; }
        public List<string> Warnings { get; set; } = new();
        public List<string> Errors { get; set; } = new();
    }
}
