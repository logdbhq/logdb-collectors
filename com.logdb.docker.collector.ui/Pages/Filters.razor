@page "/filters"
@inject IHttpClientFactory HttpClientFactory

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="page-title mb-0"><i class="bi bi-funnel me-2"></i>Filters</h4>
</div>

@if (_connectError is not null)
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>@_connectError</div>
}
else if (_rules is null)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
}
else
{
    <p class="text-muted mb-3" style="font-size: 0.85rem;">
        Exclude log records from the export pipeline by message content or .NET logger category.
        Records matching these rules will still appear in the Live Console but won't be sent to LogDB.
    </p>

    @* Exclude Message Patterns *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center py-2 px-3">
            <span class="card-title-label"><i class="bi bi-chat-left-text me-1"></i> Exclude Message Patterns</span>
            <span class="badge bg-info">@_rules.ExcludeMessagePatterns.Count rules</span>
        </div>
        <div class="card-body p-3">
            <p class="text-muted mb-2" style="font-size: 0.85rem;">Log records containing these text patterns will be excluded from export. Substring match, case-insensitive.</p>

            <div class="d-flex gap-2 mb-3">
                <input type="text" class="form-control form-control-sm" placeholder="e.g. health check, GET /healthz, Heartbeat" @bind="_newMessage" @bind:event="oninput"
                       @onkeydown="@(async e => { if (e.Key == "Enter") await AddMessage(); })" />
                <button class="btn btn-sm btn-primary flex-shrink-0" @onclick="AddMessage" disabled="@(string.IsNullOrWhiteSpace(_newMessage) || _saving)">
                    <i class="bi bi-plus-lg"></i> Add
                </button>
            </div>

            @if (_rules.ExcludeMessagePatterns.Count == 0)
            {
                <div class="text-muted text-center py-2" style="font-size: 0.85rem;">No message exclusions configured</div>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var pattern in _rules.ExcludeMessagePatterns)
                    {
                        var p = pattern;
                        <span class="badge d-flex align-items-center gap-1 filter-tag">
                            <code>@p</code>
                            <button class="btn-close btn-close-white filter-tag-remove" @onclick="() => RemoveMessage(p)" disabled="@_saving"></button>
                        </span>
                    }
                </div>
            }
        </div>
    </div>

    @* Exclude Categories *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center py-2 px-3">
            <span class="card-title-label"><i class="bi bi-tag me-1"></i> Exclude Categories</span>
            <span class="badge bg-info">@_rules.ExcludeCategories.Count rules</span>
        </div>
        <div class="card-body p-3">
            <p class="text-muted mb-2" style="font-size: 0.85rem;">
                .NET logger categories to exclude. These are parsed from ConsoleLogger output headers
                (e.g. <code>Microsoft.AspNetCore.Hosting.Diagnostics</code>). Exact match, case-insensitive.
            </p>

            <div class="d-flex gap-2 mb-3">
                <input type="text" class="form-control form-control-sm" placeholder="e.g. Microsoft.AspNetCore.Hosting.Diagnostics" @bind="_newCategory" @bind:event="oninput"
                       @onkeydown="@(async e => { if (e.Key == "Enter") await AddCategory(); })" />
                <button class="btn btn-sm btn-primary flex-shrink-0" @onclick="AddCategory" disabled="@(string.IsNullOrWhiteSpace(_newCategory) || _saving)">
                    <i class="bi bi-plus-lg"></i> Add
                </button>
            </div>

            @if (_rules.ExcludeCategories.Count == 0)
            {
                <div class="text-muted text-center py-2" style="font-size: 0.85rem;">No category exclusions configured</div>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var cat in _rules.ExcludeCategories)
                    {
                        var c = cat;
                        <span class="badge d-flex align-items-center gap-1 filter-tag">
                            <code>@c</code>
                            <button class="btn-close btn-close-white filter-tag-remove" @onclick="() => RemoveCategory(c)" disabled="@_saving"></button>
                        </span>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
    .filter-tag {
        font-size: 0.85rem;
        padding: 0.35em 0.6em;
        font-weight: normal;
        background: var(--danger-muted) !important;
        border: 1px solid var(--danger-color) !important;
        color: var(--danger-color) !important;
    }

    .filter-tag code {
        color: inherit;
        font-size: 0.85rem;
    }

    .filter-tag-remove {
        font-size: 0.6rem;
        padding: 0.25em;
        margin-left: 0.3em;
        opacity: 1;
        cursor: pointer;
        background-size: 0.6rem;
        filter: brightness(2);
    }

    .filter-tag-remove:hover {
        transform: scale(1.2);
    }
</style>

@code {
    private FilterRulesDto? _rules;
    private string? _connectError;
    private string? _newMessage;
    private string? _newCategory;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("DockerCollectorApi");
            _rules = await client.GetFromJsonAsync<FilterRulesDto>("/api/filters");
            _connectError = null;
        }
        catch (Exception ex)
        {
            _connectError = ex.Message;
        }
    }

    private async Task AddMessage()
    {
        if (string.IsNullOrWhiteSpace(_newMessage)) return;
        _saving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("DockerCollectorApi");
            var response = await client.PostAsJsonAsync("/api/filters/exclude-message", new { value = _newMessage.Trim() });
            _rules = await response.Content.ReadFromJsonAsync<FilterRulesDto>();
            _newMessage = "";
            _connectError = null;
        }
        catch (Exception ex) { _connectError = ex.Message; }
        finally { _saving = false; }
    }

    private async Task RemoveMessage(string pattern)
    {
        _saving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("DockerCollectorApi");
            var response = await client.DeleteAsync($"/api/filters/exclude-message?value={Uri.EscapeDataString(pattern)}");
            _rules = await response.Content.ReadFromJsonAsync<FilterRulesDto>();
            _connectError = null;
        }
        catch (Exception ex) { _connectError = ex.Message; }
        finally { _saving = false; }
    }

    private async Task AddCategory()
    {
        if (string.IsNullOrWhiteSpace(_newCategory)) return;
        _saving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("DockerCollectorApi");
            var response = await client.PostAsJsonAsync("/api/filters/exclude-category", new { value = _newCategory.Trim() });
            _rules = await response.Content.ReadFromJsonAsync<FilterRulesDto>();
            _newCategory = "";
            _connectError = null;
        }
        catch (Exception ex) { _connectError = ex.Message; }
        finally { _saving = false; }
    }

    private async Task RemoveCategory(string category)
    {
        _saving = true;
        try
        {
            var client = HttpClientFactory.CreateClient("DockerCollectorApi");
            var response = await client.DeleteAsync($"/api/filters/exclude-category?value={Uri.EscapeDataString(category)}");
            _rules = await response.Content.ReadFromJsonAsync<FilterRulesDto>();
            _connectError = null;
        }
        catch (Exception ex) { _connectError = ex.Message; }
        finally { _saving = false; }
    }

    private class FilterRulesDto
    {
        public List<string> ExcludeMessagePatterns { get; set; } = new();
        public List<string> ExcludeCategories { get; set; } = new();
    }
}
