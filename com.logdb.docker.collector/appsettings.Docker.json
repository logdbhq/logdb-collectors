{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "LogDbExporter": {
    "Enabled": true
  },
  "Checkpoint": {
    "FilePath": "/var/lib/logdb-collector/checkpoints.json"
  },
  "Spool": {
    "DirectoryPath": "/var/lib/logdb-collector/spool"
  }
}
