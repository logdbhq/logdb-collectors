{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DockerDiscovery": {
    "RefreshIntervalSeconds": 30
  },
  "CollectorFilter": {
    "IncludeContainerNames": [],
    "ExcludeContainerNames": [],
    "IncludeImages": [],
    "ExcludeImages": [],
    "IncludeLabels": {},
    "ExcludeLabels": {}
  },
  "Checkpoint": {
    "Enabled": true,
    "FilePath": "checkpoints.json",
    "FlushIntervalSeconds": 15
  },
  "LogDbExporter": {
    "Enabled": false,
    "Endpoint": "http://localhost:5000",
    "ApiKey": "",
    "Collection": "docker-logs",
    "Protocol": "Native",
    "FlushIntervalSeconds": 5,
    "MaxBatchBytes": 1048576,
    "MaxRetries": 3,
    "EnableCompression": true,
    "RequestTimeoutSeconds": 30
  },
  "DockerMetrics": {
    "Enabled": true,
    "CollectionIntervalSeconds": 30,
    "MaxConcurrentStats": 8,
    "StatsTimeoutSeconds": 5,
    "IncludeStoppedContainers": false,
    "IncludeHealthCheck": true
  },
  "Spool": {
    "Enabled": true,
    "DirectoryPath": "spool",
    "MaxDiskBytes": 2147483648,
    "MaxSegmentBytes": 10485760,
    "FlushIntervalSeconds": 1,
    "WhenFull": "DropOldest"
  }
}
